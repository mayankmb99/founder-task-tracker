{"id":"tx-01","description":"Clear user-owned action item with relative date and exact time.","input":{"message":"I'll send Arjun the proposal tomorrow by 4 PM.","source":"gmail","reference_date":"2026-06-20","timezone":"Asia/Kolkata"},"expected_interaction_type":"task_extraction","must_include_criteria":["classify as action item","resolve tomorrow to the next day","extract the due time","keep the owner as user"],"must_not_include_criteria":["invent a different date","invent extra context","mark as non-action"],"expected_structured_fields":{"is_action_item":true,"task_owner":"user","action_type":"create","task_title":"Send Arjun the proposal","due_date":"2026-06-21","due_time":"16:00","confidence_min":0.85,"missing_information":[]},"grounding_requirements":["Use only the message text and reference date","Do not invent any missing recipient context"],"notes":"Happy-path extraction with full approval path."}
